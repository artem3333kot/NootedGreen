{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MMIO Linux Canonical Mapping",
  "type": "object",
  "required": ["platform", "results"],
  "additionalProperties": false,
  "properties": {
    "platform": {
      "type": "string",
      "description": "GPU generation/platform, e.g., ICL, TGL, ADL"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "address",
          "platform",
          "canonical_linux_symbol",
          "canonical_source",
          "apple_aliases",
          "confidence",
          "evidence",
          "status"
        ],
        "properties": {
          "address": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]+$"
          },
          "platform": {
            "type": "string"
          },
          "canonical_linux_symbol": {
            "type": "string",
            "description": "Exact Linux symbol or UNKNOWN_<hexaddr>"
          },
          "canonical_source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "path", "line", "macro_text"],
            "properties": {
              "repo": { "type": "string" },
              "path": { "type": "string" },
              "line": { "type": "integer", "minimum": 1 },
              "macro_text": { "type": "string" }
            }
          },
          "apple_aliases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW"]
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "exact_address_match",
              "platform_match",
              "usage_match",
              "bitfield_match",
              "ambiguity_notes",
              "score"
            ],
            "properties": {
              "exact_address_match": { "type": "boolean" },
              "platform_match": { "type": "boolean" },
              "usage_match": { "type": "boolean" },
              "bitfield_match": { "type": "boolean" },
              "ambiguity_notes": { "type": "string" },
              "score": { "type": "integer", "minimum": -20, "maximum": 20 }
            }
          },
          "status": {
            "type": "string",
            "enum": ["AUTO_RENAME", "REVIEW_REQUIRED", "REJECTED"]
          }
        }
      }
    }
  }
}
